<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Add Book</title>
</head>
<body>
  <h1>Add New Book</h1>

  <form action="/api/admin/cards" method="POST" enctype="multipart/form-data">
    <label>Title:
      <input type="text" name="title" required>
    </label><br/>

    <label>Category:
      <select name="category" required>
        <option value="NCERT Highlights">NCERT Highlights</option>
        <option value="Physics">Physics</option>
        <option value="Biology">Biology</option>
        <option value="Chemistry">Chemistry</option>
        <option value="JEE">JEE</option>
        <option value="NEET">NEET</option>
        <!-- Add more if needed -->
      </select>
    </label><br/>

    <label>Original Price:
      <input type="number" name="originalPrice" required>
    </label><br/>

    <label>Discounted Price:
      <input type="number" name="discountedPrice" required>
    </label><br/>

    <label>Badge Text (like "90% OFF"):
      <input type="text" name="badge" required>
    </label><br/>

    <label>Demo:
      <input type="text" name="demo" placeholder="Yes / No">
    </label><br/>

    <label>Image:
      <input type="file" name="image" accept="image/*" required>
    </label><br/>

    <button type="submit">Add Book</button>
  </form>
</body>
</html>
