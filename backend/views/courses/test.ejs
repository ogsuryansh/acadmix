<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Tests | Acadmix</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      /* same responsive styling */
      body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: #f9f9f9;
        color: #333;
      }
      header {
        background-color: #ff5722;
        padding: 1rem 2rem;
        color: #fff;
        text-align: center;
      }
      .tabs {
        display: flex;
        justify-content: center;
        margin: 2rem 0;
        gap: 1rem;
      }
      .tab-button {
        padding: 0.75rem 1.5rem;
        border: none;
        background-color: #ddd;
        color: #333;
        font-weight: bold;
        cursor: pointer;
        border-radius: 6px;
        transition: background 0.3s ease;
      }
      .tab-button.active {
        background-color: #ff5722;
        color: #fff;
      }
      #card-container {
        padding: 1rem;
      }
      .cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        padding: 2rem;
        max-width: 1200px;
        margin: auto;
      }
      @media (max-width: 768px) {
        .cards {
          grid-template-columns: 1fr;
          padding: 1rem;
        }
      }
      .card {
        background: #f9ebea;
        border: 1px solid #f2d7d5;
        border-radius: 12px;
        box-shadow: 0 4px 12px rgba(230, 176, 170, 0.4);
        transition: background 0.3s, transform 0.3s, box-shadow 0.3s;
        overflow: hidden;
        color: black;
        text-align: center;
        padding: 1rem;
      }
      .card img {
        width: 100%;
        height: 180px;
        object-fit: cover;
        border-radius: 8px;
        margin-bottom: 1rem;
      }
      .card h3 {
        font-size: 1.1rem;
        margin: 0.5rem 0;
      }
      .card p {
        margin: 0.25rem 0;
      }
      .coming-soon {
        text-align: center;
        padding: 2rem;
        color: #777;
      }
    </style>
  </head>
  <body>
    <header><h1>Tests Courses</h1></header>
    <div class="tabs">
      <button class="tab-button active" data-target="NEET">NEET</button>
      <button class="tab-button" data-target="JEE">JEE</button>
    </div>
    <div id="card-container">
      <div class="coming-soon">📚 Loading content...</div>
    </div>

    <script>
      let PAGE_SECTION = "test";
      let currentTrack = "NEET";
      const API_BASE = "https://acadmix-opal.vercel.app";

      function fetchAndRenderCards() {
        fetch(`${API_BASE}/api/books`)
          .then((res) => res.json())
          .then((cards) => {
            const container = document.getElementById("card-container");
            container.innerHTML = "";
            const filtered = cards.filter(
              (c) => c.section === PAGE_SECTION && c.track === currentTrack
            );
            if (filtered.length === 0) {
              container.innerHTML = `<div class="coming-soon">📚 ${currentTrack} Content Coming Soon</div>`;
              return;
            }
            const wrapper = document.createElement("div");
            wrapper.className = "cards";
            filtered.forEach((book) => {
              const el = document.createElement("div");
              el.className = "card";
              el.innerHTML = `
              <img src="${book.imageUrl}" alt="${book.title}" />
              <h3>${book.title}</h3>
              <p>₹<s>${book.priceOriginal}</s> <strong>₹${book.priceDiscounted}</strong></p>
              <p>${book.badge}</p>
            `;
              wrapper.appendChild(el);
            });
            container.appendChild(wrapper);
          })
          .catch((err) => {
            console.error("Fetch error:", err);
            document.getElementById("card-container").innerHTML =
              "<p>Error loading materials</p>";
          });
      }

      fetchAndRenderCards();
      document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll(".tab-button").forEach((btn) => {
          btn.addEventListener("click", () => {
            document
              .querySelectorAll(".tab-button")
              .forEach((b) => b.classList.remove("active"));
            btn.classList.add("active");
            currentTrack = btn.dataset.target;
            fetchAndRenderCards();
          });
        });
      });
    </script>
  </body>
</html>
