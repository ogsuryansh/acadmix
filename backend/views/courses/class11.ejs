<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Class 11 | Acadmix</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
   /* Global styles */
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #f9f9f9;
  color: #333;
}

header {
  background-color: #ff5722;
  padding: 1rem 2rem;
  color: #fff;
  text-align: center;
}

.tabs {
  display: flex;
  justify-content: center;
  margin: 2rem 0;
  gap: 1rem;
}

.tab-button {
  padding: 0.75rem 1.5rem;
  border: none;
  background-color: #ddd;
  color: #333;
  font-weight: bold;
  cursor: pointer;
  border-radius: 6px;
  transition: background 0.3s ease;
}

.tab-button.active {
  background-color: #ff5722;
  color: #fff;
}

#card-container {
  padding: 1rem;
}

.lable {
  padding: 10px;
  font-size: 2rem;
  font-weight: 800;
  width: 100%;
  color: #fff;
}

.coming-soon {
  text-align: center;
  padding: 2rem;
  color: #777;
}

/* Card grid */
.cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
  padding: 2rem;
  max-width: 1200px;
  margin: auto;
}

@media (max-width: 768px) {
  .cards {
    grid-template-columns: 1fr;
    padding: 1rem;
  }
}

/* Card design */
.card {
  background: #f9ebea;
  border: 1px solid #f2d7d5;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 4px 12px rgba(230, 176, 170, 0.4);
  transition: background 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  transform-origin: center center;
  color: black;
  text-align: center;
  padding: 1rem;
}

.card:hover {
  transform: scale(1.05);
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.5);
}

.card-image {
  position: relative;
  width: 100%;
  padding-bottom: 56%;
  overflow: hidden;
}

.card-image img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.badge {
  position: absolute;
  top: 0.75rem;
  left: 0.75rem;
  background: #e00;
  color: #fff;
  font-size: 0.75rem;
  font-weight: 600;
  padding: 0.25rem 0.5rem;
  border-radius: 4px;
}

.card-body {
  padding: 1rem;
}

.category {
  font-size: 0.75rem;
  font-weight: 600;
  color: #776dff;
  text-transform: uppercase;
  margin-bottom: 0.25rem;
}

.card-title {
  font-size: 1.1rem;
  font-weight: 600;
  margin: 0.25rem 0 0.75rem;
}

.price {
  display: flex;
  align-items: baseline;
  gap: 0.5rem;
  margin-bottom: 0.5rem;
  justify-content: center;
}

.price .original {
  font-size: 0.9rem;
  text-decoration: line-through;
}

.price .discount {
  font-size: 1.25rem;
  font-weight: 700;
}

.demo {
  font-size: 0.85rem;
  margin-bottom: 1rem;
}

.btn-buy {
  display: inline-block;
  background: #ffcc00;
  color: #000;
  font-weight: 600;
  text-decoration: none;
  padding: 0.5rem 1rem;
  border-radius: 6px;
  transition: background 0.3s ease;
}

.btn-buy:hover {
  background: #e6b800;
}

  </style>
</head>
<body>
  <header>
    <h1>Class 11 Courses</h1>
  </header>

  <div class="tabs">
    <button class="tab-button active" data-target="NEET">NEET</button>
    <button class="tab-button" data-target="JEE">JEE</button>
  </div>

  <div id="card-container">
    <!-- Cards will be injected here -->
    <div class="coming-soon">📚 Loading content...</div>
  </div>

  <script>
    let PAGE_SECTION = "class11";
    let currentTrack = "NEET";

    const API_BASE = 'https://acadmix-opal.vercel.app';

    function fetchAndRenderCards() {
      fetch(`${API_BASE}/api/books`)
        .then(res => res.json())
        .then(cards => {
          const container = document.getElementById("card-container");
          container.innerHTML = "";

          const filteredCards = cards.filter(card =>
            card.section === PAGE_SECTION && card.track === currentTrack
          );

          if (filteredCards.length === 0) {
            container.innerHTML = `<div class="coming-soon">📚 ${currentTrack} Content Coming Soon</div>`;
            return;
          }

          const cardsWrapper = document.createElement("div");
          cardsWrapper.className = "cards";

          filteredCards.forEach(card => {
            const cardEl = document.createElement("div");
            cardEl.className = "card";
            cardEl.innerHTML = `
              <div class="card-image">
                <img src="${card.imageUrl}" alt="${card.title}" />
                <div class="badge">${card.badge || ""}</div>
              </div>
              <div class="card-body">
                <div class="category">${card.category}</div>
                <h3 class="card-title">${card.title}</h3>
                <div class="price">
                  <span class="original">₹${card.priceOriginal}</span>
                  <span class="discount">₹${card.priceDiscounted}</span>
                </div>
                <div class="demo">${card.demo || "No Demo"}</div>
                <a href="#" class="btn-buy">Buy Now</a>
              </div>
            `;
            cardsWrapper.appendChild(cardEl);
          });

          container.appendChild(cardsWrapper);
        })
        .catch(err => {
          console.error("Error fetching cards:", err);
          document.getElementById("card-container").innerHTML =
            "<p>Error loading materials</p>";
        });
    }

    // Initial fetch
    fetchAndRenderCards();

    // Tab switching
    document.addEventListener('DOMContentLoaded', () => {
      const buttons = document.querySelectorAll('.tab-button');
      buttons.forEach(button => {
        button.addEventListener('click', () => {
          buttons.forEach(btn => btn.classList.remove('active'));
          button.classList.add('active');
          currentTrack = button.dataset.target;
          fetchAndRenderCards();
        });
      });
    });
  </script>
</body>
</html>
