<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Class 12 | Acadmix</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f9f9f9;
      color: #333;
    }

    header {
      background-color: #ff5722;
      padding: 1rem 2rem;
      color: #fff;
      text-align: center;
    }

    .tabs {
      display: flex;
      justify-content: center;
      margin: 2rem 0;
    }

    .tab-button {
      padding: 0.75rem 1.5rem;
      margin: 0 0.5rem;
      border: none;
      background-color: #ddd;
      color: #333;
      font-weight: bold;
      cursor: pointer;
      border-radius: 6px;
      transition: background 0.3s ease;
    }

    .tab-button.active {
      background-color: #ff5722;
      color: #fff;
    }

    .tab-content {
      display: none;
      padding: 1rem 2rem;
    }

    .tab-content.active {
      display: block;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 2rem;
      padding: 2rem;
    }

    .card {
      background: #fff;
      border: 1px solid #ccc;
      border-radius: 10px;
      padding: 1rem;
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.05);
      text-align: center;
    }

    .card img {
      max-width: 100%;
      height: 200px;
      object-fit: cover;
      border-radius: 6px;
    }

    .card h3 {
      margin: 0.5rem 0;
    }

    .coming-soon {
      text-align: center;
      font-size: 1.2rem;
      color: #777;
      margin-top: 2rem;
    }
  </style>
</head>
<body>
  <header>
    <h1>Class 12 Courses</h1>
  </header>

  <div class="tabs">
    <button class="tab-button active" data-target="neet">NEET</button>
    <button class="tab-button" data-target="jee">JEE</button>
  </div>

  <div id="neet" class="tab-content active">
    <% if (neetBooks.length > 0) { %>
      <div class="cards">
        <% neetBooks.forEach(book => { %>
          <div class="card">
            <img src="<%= book.imageUrl %>" alt="<%= book.title %>">
            <h3><%= book.title %></h3>
            <p><strong>₹<%= book.priceDiscounted %></strong> <s>₹<%= book.priceOriginal %></s></p>
            <% if (book.badge) { %><p><em><%= book.badge %></em></p><% } %>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="coming-soon">NEET content coming soon.</div>
    <% } %>
  </div>

  <div id="jee" class="tab-content">
    <% if (jeeBooks.length > 0) { %>
      <div class="cards">
        <% jeeBooks.forEach(book => { %>
          <div class="card">
            <img src="<%= book.imageUrl %>" alt="<%= book.title %>">
            <h3><%= book.title %></h3>
            <p><strong>₹<%= book.priceDiscounted %></strong> <s>₹<%= book.priceOriginal %></s></p>
            <% if (book.badge) { %><p><em><%= book.badge %></em></p><% } %>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="coming-soon">JEE content coming soon.</div>
    <% } %>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const buttons = document.querySelectorAll('.tab-button');
      const contents = document.querySelectorAll('.tab-content');

      buttons.forEach(button => {
        button.addEventListener('click', () => {
          buttons.forEach(btn => btn.classList.remove('active'));
          contents.forEach(section => section.classList.remove('active'));

          button.classList.add('active');
          document.getElementById(button.dataset.target).classList.add('active');
        });
      });
    });
  </script>
</body>
</html>
