<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Book Management</title>
    <style>
      body {
        font-family: sans-serif;
        padding: 2rem;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
      }
      th,
      td {
        border: 1px solid #ccc;
        padding: 10px;
        text-align: center;
      }
      th {
        background: #f4f4f4;
      }
      img {
        width: 60px;
        border-radius: 8px;
      }
      .actions form {
        display: inline;
      }
      .btn-add {
        display: inline-block;
        margin-bottom: 20px;
        padding: 10px 16px;
        background: #ff5722;
        color: #fff;
        text-decoration: none;
        border-radius: 6px;
      }
      .btn-edit,
      .btn-delete,
      .btn-preview {
        padding: 6px 10px;
        text-decoration: none;
        border-radius: 4px;
        margin: 2px;
        display: inline-block;
      }
      .btn-edit {
        background: #2196f3;
        color: #fff;
      }
      .btn-delete {
        background: #f44336;
        color: #fff;
        border: none;
        cursor: pointer;
      }
      .btn-preview {
        background: #4caf50;
        color: #fff;
      }
    </style>
  </head>
  <body>
    <h1>Books Management</h1>

    <a href="/api/admin/books/new" class="btn-add">+ Add New Book</a>

    <table>
      <thead>
        <tr>
          <th>Image</th>
          <th>Title</th>
          <th>Category</th>
          <th>Section</th>
          <th>Price</th>
          <th>Discount</th>
          <th>Badge</th>
          <th>Demo</th>
          <th>PDF</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% books.forEach(book => { %>
        <tr>
          <td><img src="<%= book.imageUrl %>" alt="book" /></td>
          <td><%= book.title %></td>
          <td><%= book.category %></td>
          <td><%= book.section %></td>
          <td>₹<%= book.priceOriginal %></td>
          <td>₹<%= book.priceDiscounted %></td>
          <td><%= book.badge %></td>
          <td><%= book.demo || "No" %></td>
          <td>
            <% if (book.pdfUrl) { %>
              <a href="<%= book.pdfUrl %>" target="_blank">View PDF</a>
            <% } else { %>
              <span style="color: gray">No PDF</span>
            <% } %>
          </td>
          <td class="actions">
            <a href="/api/admin/books/<%= book._id %>/edit" class="btn-edit">✏️ Edit</a>
            <a href="/reader?id=<%= book._id %>" class="btn-preview" target="_blank">👁️ Preview</a>
            <form
              action="/api/admin/books/<%= book._id %>/delete"
              method="POST"
              onsubmit="return confirm('Are you sure you want to delete this book?');"
            >
              <button type="submit" class="btn-delete">🗑️ Delete</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </body>
</html>
