<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Book Management</title>
  <style>
    table { width: 100%; border-collapse: collapse; margin-top: 20px; }
    th, td { border: 1px solid #ccc; padding: 10px; text-align: center; }
    th { background: #f4f4f4; }
    img { width: 60px; border-radius: 8px; }
    .actions form { display: inline; }
  </style>
</head>
<body>
  <h1>Books Management</h1>

  <a href="/api/admin/books/new" class="btn btn-add">+ Add New Book</a>


  <table>
    <thead>
      <tr>
        <th>Image</th>
        <th>Title</th>
        <th>Category</th>
        <th>Price</th>
        <th>Discount</th>
        <th>Badge</th>
        <th>Demo</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% books.forEach(book => { %>
        <tr>
          <td><img src="<%= book.image %>" alt="book" /></td>
          <td><%= book.title %></td>
          <td><%= book.category %></td>
          <td>₹<%= book.originalPrice %></td>
          <td>₹<%= book.discountedPrice %></td>
          <td><%= book.badge %></td>
          <td><%= book.demo %></td>
          <td class="actions">
            <form action="/api/admin/cards/<%= book._id %>?_method=DELETE" method="POST">
              <button type="submit">🗑️ Delete</button>
            </form>
            <a href="/api/admin/cards/<%= book._id %>/edit">✏️ Edit</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</body>
</html>
