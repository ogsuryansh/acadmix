<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Acadmix Admin Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    :root {
      --primary: #ff5722;
      --background: #f5f5f5;
      --card-bg: #fff;
      --text: #333;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', sans-serif;
      background-color: var(--background);
      color: var(--text);
    }

    .admin-container {
      display: flex;
      min-height: 100vh;
    }

    .sidebar {
      width: 220px;
      background: var(--primary);
      color: #fff;
      padding: 2rem 1rem;
    }

    .sidebar h2 {
      margin-bottom: 2rem;
      text-align: center;
    }

    .sidebar button {
      display: block;
      background: none;
      border: none;
      color: #fff;
      font-weight: bold;
      margin: 1rem 0;
      text-align: left;
      cursor: pointer;
      font-size: 1rem;
    }

    .main {
      flex: 1;
      padding: 2rem;
    }

    .tab-content {
      display: none;
    }

    .tab-content.active {
      display: block;
    }

    .dashboard-cards {
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
      margin-bottom: 2rem;
    }

    .card {
      background: var(--card-bg);
      padding: 1.5rem;
      border-radius: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      flex: 1;
      min-width: 200px;
      text-align: center;
    }

    .card h3 {
      margin-bottom: 0.5rem;
      color: var(--primary);
    }

    table {
      width: 100%;
      background: #fff;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    th, td {
      padding: 1rem;
      text-align: left;
      border-bottom: 1px solid #eee;
    }

    th {
      background: #fafafa;
    }

    img.user-img {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      object-fit: cover;
      margin-right: 8px;
    }

    .user-info {
      display: flex;
      align-items: center;
    }

    .books-buttons {
      display: flex;
      gap: 1rem;
      margin-bottom: 2rem;
      flex-wrap: wrap;
    }

    .books-buttons a {
      padding: 0.75rem 1.25rem;
      background: var(--primary);
      color: #fff;
      text-decoration: none;
      border-radius: 6px;
      font-weight: bold;
      transition: background 0.2s ease;
    }

    .books-buttons a:hover {
      background: #d94c1c;
    }

    @media(max-width: 768px) {
      .dashboard-cards {
        flex-direction: column;
      }
      .sidebar {
        display: none;
      }
    }
  </style>
</head>
<body>
  <div class="admin-container">
    <!-- Sidebar -->
    <div class="sidebar">
      <h2>Admin</h2>
      <button onclick="switchTab('dashboard')">Dashboard</button>
      <button onclick="switchTab('books')">Books</button>
      <button onclick="switchTab('payments')">Payments</button>
      <form action="/api/admin/logout" method="POST" style="margin-top: 2rem;">
        <button type="submit" style="color:#fff;">Logout</button>
      </form>
    </div>

    <!-- Main Content -->
    <div class="main">
      <!-- DASHBOARD TAB -->
      <div id="dashboard" class="tab-content active">
        <h1>Dashboard</h1>
        <div class="dashboard-cards">
          <div class="card">
            <h3>Total Users</h3>
            <p><%= totalUsers %></p>
          </div>
          <div class="card">
            <h3>Total Payments</h3>
            <p><%= totalPayments %></p>
          </div>
          <div class="card">
            <h3>Total Books</h3>
            <p><%= totalBooks %></p>
          </div>
        </div>

        <h2>All Users</h2>
        <table>
          <thead>
            <tr>
              <th>User</th>
              <th>Email</th>
              <th>Books</th>
              <th>Joined</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(user => { %>
              <tr>
                <td class="user-info">
                  <img src="<%= user.photo %>" alt="user" class="user-img" />
                  <%= user.name %>
                </td>
                <td><%= user.email %></td>
                <td>
                  <% if (user.books && user.books.length > 0) { %>
                    <%= user.books.join(", ") %>
                  <% } else { %>
                    None
                  <% } %>
                </td>
                <td><%= new Date(user.createdAt).toLocaleDateString() %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- BOOKS TAB -->
      <div id="books" class="tab-content">
        <h1>Books Dashboard</h1>
        <div class="books-buttons">
          <a href="/api/admin/books">Show Books</a>
          <a href="/api/admin/books/new">Add New Book</a>
          <a href="/api/admin/books">Edit Book</a>
          <a href="/api/admin/books">Delete Book</a>
        </div>
        <p>Select one of the above actions to manage books.</p>
      </div>

      <!-- PAYMENTS TAB -->
      <div id="payments" class="tab-content">
        <h1>Payments Dashboard</h1>
        <p>Payments stats and actions coming soon.</p>
      </div>
    </div>
  </div>

  <script>
    function switchTab(tabId) {
      document.querySelectorAll('.tab-content').forEach(tab => {
        tab.classList.remove('active');
      });
      document.getElementById(tabId).classList.add('active');
    }
  </script>
</body>
</html>
