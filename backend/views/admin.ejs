<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Acadmix Admin Dashboard</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      :root {
        --primary: #ff5722;
        --background: #f5f5f5;
        --card-bg: #fff;
        --text: #333;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Segoe UI", sans-serif;
        background-color: var(--background);
        color: var(--text);
      }

      .admin-container {
        display: flex;
        min-height: 100vh;
      }

      .sidebar {
        width: 220px;
        background: var(--primary);
        color: #fff;
        padding: 2rem 1rem;
        transition: transform 0.3s ease;
      }

      .sidebar h2 {
        margin-bottom: 2rem;
        text-align: center;
      }

      .sidebar a {
        display: block;
        color: #fff;
        text-decoration: none;
        margin: 1rem 0;
        font-weight: bold;
        cursor: pointer;
      }

      .hamburger {
        display: none;
        font-size: 1.8rem;
        cursor: pointer;
        margin: 1rem;
      }

      .close-btn {
        display: none;
        font-size: 1.5rem;
        color: #fff;
        text-align: right;
        cursor: pointer;
      }

      .main {
        flex: 1;
        padding: 2rem;
      }

      .tab {
        display: none;
      }

      .tab.active {
        display: block;
      }

      .dashboard-cards {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
        margin-bottom: 2rem;
      }

      .card {
        background: var(--card-bg);
        padding: 1.5rem;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        flex: 1;
        min-width: 200px;
        text-align: center;
      }

      .card h3 {
        margin-bottom: 0.5rem;
        color: var(--primary);
      }

      table {
        width: 100%;
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      }

      th,
      td {
        padding: 1rem;
        text-align: left;
        border-bottom: 1px solid #eee;
      }

      th {
        background: #fafafa;
      }

      img.user-img {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        object-fit: cover;
        margin-right: 8px;
      }

      .user-info {
        display: flex;
        align-items: center;
      }

      /* Responsive */
      @media (max-width: 768px) {
        .hamburger {
          display: block;
        }
        .sidebar {
          position: fixed;
          top: 0;
          left: 0;
          height: 100%;
          transform: translateX(-100%);
          z-index: 999;
        }
        .sidebar.show {
          transform: translateX(0);
        }
        .close-btn {
          display: block;
          margin-bottom: 1rem;
        }
      }

      .btn-group {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin: 1rem 0;
      }

      .btn-group a {
        padding: 0.5rem 1rem;
        background: var(--primary);
        color: #fff;
        border-radius: 5px;
        text-decoration: none;
        font-weight: bold;
      }

      /* Payment actions */
      .actions form {
        display: inline;
        margin-right: 0.5rem;
      }
      .actions button {
        padding: 0.3rem 0.6rem;
        border: none;
        border-radius: 4px;
        cursor: pointer;
      }
      .actions .approve {
        background: #28a745;
        color: #fff;
      }
      .actions .reject {
        background: #dc3545;
        color: #fff;
      }
    </style>
  </head>
  <body>
    <div class="admin-container">
      <!-- Sidebar -->
      <div class="sidebar" id="sidebar">
        <div class="close-btn" id="closeSidebar">✖</div>
        <h2>Admin</h2>
        <a data-tab="dashboard-tab">Dashboard</a>
        <a data-tab="books-tab">Books</a>
        <a data-tab="payments-tab">Payments</a>
        <a href="/api/admin/logout">Logout</a>
      </div>

      <!-- Main Content -->
      <div class="main">
        <div class="hamburger" id="openSidebar">☰</div>

        <!-- Dashboard Tab -->
        <div class="tab active" id="dashboard-tab">
          <h1>Dashboard</h1>
          <div class="dashboard-cards">
            <div class="card">
              <h3>Total Users</h3>
              <p><%= totalUsers %></p>
            </div>
            <div class="card">
              <h3>Total Payments</h3>
              <p><%= totalPayments %></p>
            </div>
            <div class="card">
              <h3>Total Books</h3>
              <p><%= totalBooks %></p>
            </div>
          </div>
          <h2>All Users</h2>
          <table>
            <thead>
              <tr>
                <th>User</th>
                <th>Email</th>
                <th>Books</th>
                <th>Joined</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(user => { %>
              <tr>
                <td class="user-info">
                  <img src="<%= user.photo %>" alt="user" class="user-img" />
                  <%= user.name %>
                </td>
                <td><%= user.email %></td>
                <td><%= user.books?.join(", ") || "None" %></td>
                <td><%= new Date(user.createdAt).toLocaleDateString() %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <!-- Books Tab -->
        <div class="tab" id="books-tab">
          <h1>Books Dashboard</h1>
          <div class="btn-group">
            <a href="/api/admin/books">Show All Books</a>
            <a href="/api/admin/books/new">Add New Book</a>
          </div>
        </div>

        <!-- Payments Tab -->
        <div class="tab" id="payments-tab">
          <h1>Payments</h1>
          <table>
            <thead>
              <tr>
                <th>User</th>
                <th>Book</th>
                <th>UTR</th>
                <th>Status</th>
                <th>Submitted</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% payments.forEach(p => { const submittedAt = new
              Date(p.submittedAt); const istOffset = 5.5 * 60 * 60 * 1000; const
              istDate = new Date(submittedAt.getTime() + istOffset); const
              istFormatted = istDate.toLocaleString("en-IN", { dateStyle:
              "medium", timeStyle: "short" }); %>
              <tr>
                <td><%= p.user.name %> (<%= p.user.email %>)</td>
                <td><%= p.book ? p.book.title : 'Deleted Book' %></td>

                <td><%= p.utr %></td>
                <td>
                  <%= p.status.charAt(0).toUpperCase() + p.status.slice(1) %>
                </td>
                <td><%= istFormatted %></td>
                <td class="actions">
                  <% if (p.status === 'pending') { %>
                  <form
                    action="/api/admin/payments/<%= p._id %>/approve"
                    method="POST"
                  >
                    <button type="submit" class="approve">Approve</button>
                  </form>
                  <form
                    action="/api/admin/payments/<%= p._id %>/reject"
                    method="POST"
                  >
                    <button type="submit" class="reject">Reject</button>
                  </form>
                  <% } else { %> &mdash; <% } %>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const sidebarLinks = document.querySelectorAll(".sidebar a[data-tab]");
        const tabs = document.querySelectorAll(".tab");

        sidebarLinks.forEach((link) => {
          link.addEventListener("click", () => {
            const tabId = link.getAttribute("data-tab");
            tabs.forEach((tab) => tab.classList.remove("active"));
            document.getElementById(tabId).classList.add("active");
          });
        });

        const sidebar = document.getElementById("sidebar");
        document
          .getElementById("openSidebar")
          .addEventListener("click", () => sidebar.classList.add("show"));
        document
          .getElementById("closeSidebar")
          .addEventListener("click", () => sidebar.classList.remove("show"));
      });
    </script>
  </body>
</html>
